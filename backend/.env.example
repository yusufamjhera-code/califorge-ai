# Server
HOST=0.0.0.0
PORT=8000

# MongoDB (Replace with your MongoDB Atlas URI)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DATABASE=califorgeai

# Firebase (Required for token verification)
# For local development, just the project ID is usually enough to verify tokens.
FIREBASE_PROJECT_ID=dummy-project

# CORS
# Comma-separated list of allowed origins
CORS_ORIGINS=["http://localhost:5173"]
